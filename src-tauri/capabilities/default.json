{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions for the main and spawned windows.",
  "windows": ["main", "chart-*"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
