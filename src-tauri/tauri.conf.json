{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogViewer",
  "version": "0.1.0",
  "identifier": "com.tacklind.logviewer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LogViewer",
        "width": 1400,
        "height": 900,
        "minWidth": 600,
        "minHeight": 400,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["csv"],
        "name": "CSV log",
        "description": "Comma-separated time-series log",
        "role": "Viewer"
      }
    ]
  }
}
